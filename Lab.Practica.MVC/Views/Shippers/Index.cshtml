@model List<Lab.Practica.MVC.Models.ShippersView>
@{
    ViewBag.Title = "Home Page";
}
<div class="container">
    <div class="row">
        <div class="col-12">
            <h1>List of Shippers</h1>
        </div>
    </div>
    <br />
    <div class="row">
        <div class="col-12">
            @Html.ActionLink("New", "Insert", null, new { @class = "btn btn-success" })
        </div>
    </div>
    <br />
    <div class="row">
        <table id="dtBasicExample" class="table table-striped table-bordered table-sm">
            <thead>
                <tr>
                    <th class="th-sm">Id</th>
                    <th class="th-sm">Company Name</th>
                    <th class="th-sm">Phone</th>
                    <th class="th-sm">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var shippers in Model)
                {
                    <tr>
                        <th scope="row">@shippers.ShipperID</th>
                        <th>@shippers.CompanyName</th>
                        <th>@shippers.Phone</th>
                        <th id="@shippers.ShipperID">
                            @Html.ActionLink("Delete", "Delete", new { id = shippers.ShipperID }, new { @class = "btn btn-danger", onclick = "return confirm('Are you sure?')" })
                        @Html.ActionLink("Edit", "Edit", new { id = shippers.ShipperID }, new { @class = "btn btn-primary" })
                    </th>
                </tr>
            }
            </tbody>
        </table>
    </div>

</div>